{
  "name": "astro-devrelish",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsup src/integration.ts --format esm --dts --out-dir . --watch",
    "build": "tsup src/integration.ts --format esm --dts --out-dir .",
    "preview": "astro preview",
    "astro": "astro",
    "db:push": "astro db push --remote",
    "check": "astro check"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "@astrojs/db": ">=0.14.0",
    "@astrojs/react": ">=4.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/db": "^0.14.3",
    "@astrojs/netlify": "^7.0.5",
    "@astrojs/node": "^10.0.4",
    "@astrojs/react": "^4.2.1",
    "cloudinary": "^2.10.0",
    "drizzle-orm": "^0.45.2",
    "marked": "^17.0.5",
    "resend": "^6.10.0",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "description": "Astro integration for adding DevRel(ish) community and gathering pages to an Astro site.",
  "main": "./integration.mjs",
  "exports": {
    ".": {
      "types": "./integration.d.ts",
      "default": "./integration.mjs"
    },
    "./db/config": "./db/config.ts",
    "./styles": "./src/styles/global.css"
  },
  "types": "./integration.d.ts",
  "files": [
    "integration.mjs",
    "integration.d.ts",
    "db/",
    "src/",
    "public/"
  ]
}